# MaKonnect environment template.
# Copy to `.env.local` and fill from the ORG secret store (Vercel / Supabase).
# NEVER commit real keys. The v1 synthetic-data demo runs fine with these blank.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret (never prefix server secrets with NEXT_PUBLIC_):
SUPABASE_SERVICE_ROLE_KEY=
